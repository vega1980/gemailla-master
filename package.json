{
  "name": "gemailla-master",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Repositorio maestro unificado de GEMAILLA AI con React, Vite y Firebase puro.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "echo 'No tests specified yet' && exit 0",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "serve": "firebase emulators:start --only hosting,auth,firestore,storage",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "rules:deploy": "firebase deploy --only firestore:rules,storage",
    "test:rules": "node --test --test-concurrency=1 tests/rules/*.test.mjs",
    "test:rules:emulators": "firebase emulators:exec --only firestore,storage --project demo-gemailla-test \"npm run test:rules\"",
    "typecheck:core": "tsc -p ./jsconfig.core.json",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:functions": "npm --prefix functions test",
    "test:e2e": "npx --yes @playwright/test@1.56.1 test",
    "test:e2e:headed": "npx --yes @playwright/test@1.56.1 test --headed",
    "test:e2e:install": "npx --yes @playwright/test@1.56.1 install --with-deps chromium",
    "test:e2e:emulators": "firebase emulators:exec --only auth,firestore,storage --project demo-gemailla-e2e \"wait-on http://localhost:8080 http://localhost:9099 http://localhost:9199 && npm run test:e2e\"",
    "validate:env": "node scripts/validate-env.js",
    "validate:env:functions": "node scripts/validate-env.js --functions",
    "validate:env:all": "node scripts/validate-env.js --all",
    "validate:secrets": "node scripts/check-no-hardcoded-secrets.js",
    "validate:architecture": "node scripts/validate-architecture.js",
    "budget:bundle": "node scripts/check-bundle-budgets.js",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "measure:architecture": "node scripts/measure-architecture.js",
    "migrate:archived": "node scripts/migrate-deleted-to-archived.mjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-aspect-ratio": "^1.1.10",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-menubar": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.84.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "firebase": "^12.15.0",
    "framer-motion": "^11.16.4",
    "input-otp": "^1.4.2",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.475.0",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.26.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.2",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-unused-imports": "^4.3.0",
    "firebase-tools": "^15.22.1",
    "globals": "^17.7.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "wait-on": "file:tools/wait-on"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.4.2"
}
