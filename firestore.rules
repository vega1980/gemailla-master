rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function currentEmail() {
      return request.auth.token.email;
    }

    function hasField(data, field) {
      return data.keys().hasAny([field]);
    }

    function hasCompanyId(data) {
      return hasField(data, 'companyId')
        && data.companyId is string
        && data.companyId.size() > 0;
    }

    function hasOwnerUid(data) {
      return hasField(data, 'ownerUid')
        && data.ownerUid is string
        && data.ownerUid == currentUid();
    }

    function ownerUidIsSelfOrMissing(data) {
      return !hasField(data, 'ownerUid') || data.ownerUid == currentUid();
    }

    function membershipId(companyId) {
      return companyId + '_' + currentUid();
    }

    function companyExists(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId));
    }

    function isCompanyOwner(companyId) {
      return signedIn()
        && companyExists(companyId)
        && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid == currentUid();
    }

    function hasActiveMembership(companyId) {
      let memberId = membershipId(companyId);
      return signedIn()
        && exists(/databases/$(database)/documents/companyMembers/$(memberId))
        && get(/databases/$(database)/documents/companyMembers/$(memberId)).data.status == 'active';
    }

    function memberRole(companyId) {
      let memberId = membershipId(companyId);
      return get(/databases/$(database)/documents/companyMembers/$(memberId)).data.role;
    }

    function hasAnyCompanyRole(companyId, roles) {
      return hasActiveMembership(companyId) && memberRole(companyId) in roles;
    }

    function canReadCompany(companyId) {
      return isCompanyOwner(companyId) || hasActiveMembership(companyId);
    }

    function canWriteCompany(companyId) {
      return isCompanyOwner(companyId)
        || hasAnyCompanyRole(companyId, ['owner', 'director', 'admin', 'editor']);
    }

    function canManageCompany(companyId) {
      return isCompanyOwner(companyId)
        || hasAnyCompanyRole(companyId, ['owner', 'director', 'admin']);
    }

    function validCompanyCreate() {
      return signedIn()
        && request.resource.data.ownerUid == currentUid()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 180;
    }

    function canCreateCompanyRecord() {
      return signedIn()
        && hasCompanyId(request.resource.data)
        && canWriteCompany(request.resource.data.companyId)
        && ownerUidIsSelfOrMissing(request.resource.data);
    }

    function canReadCompanyRecord() {
      return signedIn()
        && hasCompanyId(resource.data)
        && canReadCompany(resource.data.companyId);
    }

    function companyIdUnchanged() {
      return hasCompanyId(resource.data)
        && hasCompanyId(request.resource.data)
        && request.resource.data.companyId == resource.data.companyId;
    }

    function ownerUidUnchangedOrSelf() {
      return !hasField(resource.data, 'ownerUid')
        || !hasField(request.resource.data, 'ownerUid')
        || request.resource.data.ownerUid == resource.data.ownerUid
        || request.resource.data.ownerUid == currentUid();
    }

    function canUpdateCompanyRecord() {
      return signedIn()
        && companyIdUnchanged()
        && canWriteCompany(resource.data.companyId)
        && ownerUidUnchangedOrSelf();
    }

    function canCreateOwnedOrCompanyRecord() {
      return signedIn()
        && ownerUidIsSelfOrMissing(request.resource.data)
        && (
          (hasCompanyId(request.resource.data) && canWriteCompany(request.resource.data.companyId))
          || hasOwnerUid(request.resource.data)
        );
    }

    function canReadOwnedOrCompanyRecord() {
      return signedIn()
        && (
          (hasCompanyId(resource.data) && canReadCompany(resource.data.companyId))
          || hasOwnerUid(resource.data)
        );
    }

    function canUpdateOwnedOrCompanyRecord() {
      return signedIn()
        && ownerUidUnchangedOrSelf()
        && (
          (hasCompanyId(resource.data) && companyIdUnchanged() && canWriteCompany(resource.data.companyId))
          || hasOwnerUid(resource.data)
        );
    }

    function hasNoDocumentPublicUrls(data) {
      return !hasField(data, 'fileUrl')
        && !hasField(data, 'file_url')
        && !hasField(data, 'downloadUrl')
        && !hasField(data, 'downloadURL')
        && !hasField(data, 'publicUrl');
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && userId == currentUid();
      allow delete: if false;
    }

    match /companies/{companyId} {
      allow create: if validCompanyCreate();
      allow read: if canReadCompany(companyId);
      allow update: if canManageCompany(companyId)
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;
    }

    match /companyMembers/{memberId} {
      allow create: if signedIn()
        && hasCompanyId(request.resource.data)
        && canManageCompany(request.resource.data.companyId)
        && request.resource.data.status in ['active', 'pending', 'archived']
        && request.resource.data.role in ['owner', 'director', 'admin', 'editor', 'viewer', 'invitado'];

      allow read: if signedIn()
        && hasCompanyId(resource.data)
        && (
          (hasField(resource.data, 'userUid') && resource.data.userUid == currentUid())
          || (hasField(resource.data, 'userEmail') && resource.data.userEmail == currentEmail())
          || canManageCompany(resource.data.companyId)
        );

      allow update: if signedIn()
        && hasCompanyId(resource.data)
        && hasCompanyId(request.resource.data)
        && request.resource.data.companyId == resource.data.companyId
        && canManageCompany(resource.data.companyId)
        && request.resource.data.role in ['owner', 'director', 'admin', 'editor', 'viewer', 'invitado']
        && request.resource.data.status in ['active', 'pending', 'archived'];

      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow create: if canCreateCompanyRecord()
        && request.resource.data.fileSize is number
        && request.resource.data.fileSize <= 15 * 1024 * 1024
        && request.resource.data.storagePath is string
        && hasNoDocumentPublicUrls(request.resource.data);
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord()
        && hasNoDocumentPublicUrls(request.resource.data);
      allow delete: if false;
    }

    match /transactions/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /crmClients/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /crmDeals/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /crmInteractions/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /employees/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /payroll/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /performanceReviews/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /kpis/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /projects/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /projectTasks/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /supportTickets/{id} {
      allow create: if canCreateCompanyRecord();
      allow read: if canReadCompanyRecord();
      allow update: if canUpdateCompanyRecord();
      allow delete: if false;
    }

    match /subscriptions/{id} {
      allow create: if canCreateOwnedOrCompanyRecord();
      allow read: if canReadOwnedOrCompanyRecord();
      allow update: if canUpdateOwnedOrCompanyRecord();
      allow delete: if false;
    }

    match /predictionLogs/{id} {
      allow create: if canCreateOwnedOrCompanyRecord();
      allow read: if canReadOwnedOrCompanyRecord();
      allow update: if canUpdateOwnedOrCompanyRecord();
      allow delete: if false;
    }

    match /aiConversations/{id} {
      allow create: if canCreateOwnedOrCompanyRecord();
      allow read: if canReadOwnedOrCompanyRecord();
      allow update: if canUpdateOwnedOrCompanyRecord();
      allow delete: if false;
    }
  }
}
