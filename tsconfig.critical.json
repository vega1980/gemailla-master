{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@modules/*": [
        "./src/modules/*"
      ]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "esnext",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "src/domain/dtos.ts",
    "src/domain/finance/transactionService.js",
    "src/shared/constants/roles.js",
    "src/shared/constants/documentTypes.js",
    "src/shared/validation/companySchemas.js",
    "src/shared/validation/memberSchemas.js",
    "src/shared/validation/documentSchemas.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
