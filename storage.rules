rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function hasCompanyClaim(companyId) {
      return signedIn()
        && request.auth.token.companyId == companyId
        && request.auth.token.membershipStatus == 'active';
    }

    function hasReadRole() {
      return request.auth.token.companyRole in [
        'owner',
        'admin',
        'editor',
        'viewer',
        'director'
      ];
    }

    function hasWriteRole() {
      return request.auth.token.companyRole in [
        'owner',
        'admin',
        'editor'
      ];
    }

    function hasAllowedContentType() {
      return request.resource.contentType in [
        'application/pdf',
        'application/xml',
        'text/xml'
      ];
    }

    function hasAllowedSize() {
      return request.resource.size < 15 * 1024 * 1024;
    }

    function hasRequiredCreateMetadata(companyId, documentId) {
      return request.resource.metadata.keys().hasAll([
          'companyId',
          'documentId'
        ])
        && request.resource.metadata.companyId == companyId
        && request.resource.metadata.documentId == documentId;
    }

    function hasRequiredExistingMetadata(companyId, documentId) {
      return resource.metadata.keys().hasAll([
          'companyId',
          'documentId'
        ])
        && resource.metadata.companyId == companyId
        && resource.metadata.documentId == documentId;
    }

    match /companies/{companyId}/documents/{documentId}/{fileName=**} {
      allow read: if hasCompanyClaim(companyId)
        && hasReadRole()
        && hasRequiredExistingMetadata(companyId, documentId);

      allow create: if hasCompanyClaim(companyId)
        && hasWriteRole()
        && hasAllowedContentType()
        && hasAllowedSize()
        && hasRequiredCreateMetadata(companyId, documentId);

      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
