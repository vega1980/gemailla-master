rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /{allPaths=**} {
      allow read, write: if false;
    }

    function signedIn() {
      return request.auth != null;
    }

    function hasCompanyToken(companyId) {
      return signedIn()
        && request.auth.token.companyId == companyId
        && request.auth.token.membershipStatus == 'active';
    }

    function activeCompanyAccess(companyId) {
      return hasCompanyToken(companyId);
    }

    function isWriterRole(role) {
      return role in ['owner', 'director', 'admin', 'editor'];
    }

    function canWriteCompanyDocuments(companyId) {
      return activeCompanyAccess(companyId)
        && isWriterRole(request.auth.token.companyRole);
    }

    function hasExistingObjectMetadata(companyId, documentId) {
      return resource.metadata != null
        && resource.metadata.keys().hasAll(['companyId', 'documentId'])
        && resource.metadata.companyId == companyId
        && resource.metadata.documentId == documentId;
    }


    function isValidMetadata(companyId, documentId) {
      let md = request.resource.metadata;
      return md != null
        && md.keys().hasAll(['companyId', 'documentId'])
        && md.companyId == companyId
        && md.documentId == documentId;
    }

    function hasAllowedDocumentContentType() {
      return request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'text/xml'
        || request.resource.contentType == 'application/xml';
    }

    function hasAllowedFileExtension(fileName) {
      return fileName.matches('(?i)^.+\\.(pdf|xml)$');
    }

    function contentTypeMatchesExtension(fileName) {
      return (fileName.matches('(?i)^.+\\.pdf$') && request.resource.contentType == 'application/pdf')
        || (fileName.matches('(?i)^.+\\.xml$') && (request.resource.contentType == 'text/xml' || request.resource.contentType == 'application/xml'));
    }

    match /companies/{companyId}/documents/{documentId}/{fileName} {

      allow read: if activeCompanyAccess(companyId)
                  && hasExistingObjectMetadata(companyId, documentId);

      allow create: if request.resource.size > 0
                    && request.resource.size < 15 * 1024 * 1024
                    && contentTypeMatchesExtension(fileName)
                    && canWriteCompanyDocuments(companyId)
                    && isValidMetadata(companyId, documentId);

      // Files are immutable once created — updates and deletes are never allowed
      allow update, delete: if false;
    }
  }
}
