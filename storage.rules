rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function hasCompanyToken(companyId) {
      return signedIn()
        && request.auth.token.companyId == companyId
        && request.auth.token.membershipStatus == 'active'
        && request.auth.token.companyRole in ['owner', 'director', 'admin', 'editor'];
    }

    function documentExists(documentId) {
      return firestore.exists(/databases/(default)/documents/documents/$(documentId));
    }

    function documentBelongsToCompany(companyId, documentId) {
      return documentExists(documentId)
        && firestore.get(/databases/(default)/documents/documents/$(documentId)).data.companyId == companyId;
    }

    function isValidCreateMetadata(companyId, documentId) {
      return request.resource.metadata != null
        && request.resource.metadata.companyId == companyId
        && request.resource.metadata.documentId == documentId;
    }

    function isValidExistingMetadata(companyId, documentId) {
      return resource.metadata != null
        && resource.metadata.companyId == companyId
        && resource.metadata.documentId == documentId;
    }

    match /companies/{companyId}/documents/{documentId}/{fileName} {

      allow read: if hasCompanyToken(companyId)
                    && isValidExistingMetadata(companyId, documentId);

      allow create: if hasCompanyToken(companyId)
                    && isValidCreateMetadata(companyId, documentId)
                    && documentBelongsToCompany(companyId, documentId)
                    && request.resource.size <= 15 * 1024 * 1024
                    && (request.resource.contentType == 'application/pdf'
                        || request.resource.contentType == 'text/xml'
                        || request.resource.contentType == 'application/xml');

      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
