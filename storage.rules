rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function hasActiveCompanyToken(companyId) {
      return signedIn()
        && request.auth.token.companyId == companyId
        && request.auth.token.membershipStatus == 'active';
    }

    function hasWritableCompanyRole() {
      return request.auth.token.companyRole in ['owner', 'director', 'admin', 'editor'];
    }

    function isValidRequestMetadata(companyId, documentId) {
      return request.resource.metadata != null
        && request.resource.metadata.companyId == companyId
        && request.resource.metadata.documentId == documentId;
    }

    function isValidExistingMetadata(companyId, documentId) {
      return resource.metadata != null
        && resource.metadata.companyId == companyId
        && resource.metadata.documentId == documentId;
    }

    function isAllowedDocumentContentType() {
      return request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'text/xml'
        || request.resource.contentType == 'application/xml';
    }

    match /companies/{companyId}/documents/{documentId}/{fileName} {

      allow read: if hasActiveCompanyToken(companyId)
                  && isValidExistingMetadata(companyId, documentId);

      allow create: if hasActiveCompanyToken(companyId)
                    && hasWritableCompanyRole()
                    && isValidRequestMetadata(companyId, documentId)
                    && request.resource.size < 15 * 1024 * 1024
                    && isAllowedDocumentContentType();

      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
