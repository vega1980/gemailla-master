rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function hasCompanyToken(companyId) {
      return signedIn() && request.auth.token.companyId == companyId;
    }

    function isValidMetadata(companyId) {
      return request.resource.metadata != null
        && request.resource.metadata.companyId == companyId;
    }

    match /companies/{companyId}/documents/{documentId}/{fileName} {

      allow read: if hasCompanyToken(companyId);

      allow create: if hasCompanyToken(companyId)
                    && isValidMetadata(companyId)
                    && request.resource.size < 15 * 1024 * 1024
                    && (request.resource.contentType == 'application/pdf'
                        || request.resource.contentType == 'text/xml'
                        || request.resource.contentType == 'application/xml');

      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
